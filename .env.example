# Anthropic — required for AI review
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub — required for GitHub PR reviews (repo scope)
GITHUB_TOKEN=ghp_your-token-here

# GitLab — required for GitLab MR reviews (api scope)
GITLAB_TOKEN=glpat-your-token-here

# GitLab host — change for self-hosted instances
GITLAB_HOST=https://gitlab.com

# Server port (optional, default 3000)
PORT=3000
